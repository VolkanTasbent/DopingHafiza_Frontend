# Fiziksel telefon: tercihen Mac LAN IP. Web ile ayni .env'de localhost kullaniyorsaniz
# (http://localhost:8085) uygulama Expo LAN bilgisinden otomatik IP'ye cevirir.
# Terminal: ifconfig | grep inet →  örnek 192.168.1.10
EXPO_PUBLIC_API_URL=http://192.168.1.10:8085

# Sadece portu degistirmek icin (varsayilan 8085):
# EXPO_PUBLIC_API_PORT=8080

# Android emülatör + .env'de localhost kullaniyorsan api otomatik 10.0.2.2'ye cevrilir.
# EXPO_PUBLIC_API_URL=http://localhost:8080

# .env degisince Metro'yu durdurup `npm start` yeniden calistir.
